{
  "name": "oobe-research-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous on-chain research agent for the OOBE Protocol x Ace Data Cloud bounty",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "scheduler": "tsx src/main.ts scheduler",
    "worker": "tsx src/main.ts worker",
    "once": "tsx src/main.ts once"
  },
  "dependencies": {
    "@acedatacloud/sdk": "^2026.504.2",
    "@acedatacloud/x402-client": "^2026.507.2",
    "@oobe-protocol-labs/synapse-client-sdk": "^2.0.6",
    "@oobe-protocol-labs/synapse-sap-sdk": "^0.19.8",
    "@solana/web3.js": "^1.98.4",
    "bullmq": "^5.58.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.6.1",
    "fast-xml-parser": "^4.5.3",
    "ioredis": "^5.7.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "pino": "^9.9.5",
    "pino-pretty": "^13.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
